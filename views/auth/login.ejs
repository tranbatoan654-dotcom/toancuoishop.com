<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Đăng nhập - Quản lý Kho</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { background: #fff; border-radius: 20px; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,.2); }
    .login-icon { width: 64px; height: 64px; background: linear-gradient(135deg, #667eea, #764ba2); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 1.8rem; margin: 0 auto 1.5rem; }
    .btn-login { background: linear-gradient(135deg, #667eea, #764ba2); border: none; color: #fff; border-radius: 10px; padding: .75rem; font-weight: 600; }
    .btn-login:hover { opacity: .9; color: #fff; }
    .form-control { border-radius: 10px; padding: .75rem 1rem; }
    .form-control:focus { box-shadow: 0 0 0 3px rgba(102,126,234,.25); border-color: #667eea; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="login-icon"><i class="bi bi-box-seam"></i></div>
    <h4 class="text-center mb-1">Đăng nhập</h4>
    <p class="text-center text-muted mb-4">Quản lý kho hàng chuyên nghiệp</p>
    <% if (error) { %>
    <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-circle me-2"></i><%= error %></div>
    <% } %>
    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label fw-medium">Tên đăng nhập</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
          <input type="text" name="username" class="form-control border-start-0" required placeholder="Nhập tên đăng nhập">
        </div>
      </div>
      <div class="mb-4">
        <label class="form-label fw-medium">Mật khẩu</label>
        <div class="input-group">
          <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
          <input type="password" name="password" class="form-control border-start-0" required placeholder="Nhập mật khẩu">
        </div>
      </div>
      <button type="submit" class="btn btn-login w-100 mb-3">Đăng nhập</button>
      <div class="text-center">
        <a href="/register" class="text-decoration-none">Chưa có tài khoản? Đăng ký</a>
      </div>
    </form>
  </div>
</body>
</html>
