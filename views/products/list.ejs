<div class="card">
  <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3 flex-wrap gap-2">
    <h5 class="mb-0"><i class="bi bi-box me-2"></i>Danh sách sản phẩm</h5>
    <a href="/products/add" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm sản phẩm</a>
  </div>
  <div class="card-body">
    <form method="GET" action="/products" class="row g-2 mb-3">
      <div class="col-md-4">
        <div class="input-group">
          <span class="input-group-text bg-light"><i class="bi bi-search"></i></span>
          <input type="text" name="search" class="form-control" placeholder="Tìm theo tên hoặc mã..." value="<%= typeof search !== 'undefined' && search ? search : '' %>">
        </div>
      </div>
      <div class="col-md-3">
        <select name="category" class="form-select">
          <option value="">Tất cả danh mục</option>
          <% if (categories) categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= typeof category !== 'undefined' && category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-3">
        <div class="form-check mt-2">
          <input class="form-check-input" type="checkbox" name="lowStock" value="1" id="lowStockCheck" <%= lowStock === '1' ? 'checked' : '' %>>
          <label class="form-check-label" for="lowStockCheck">Chỉ sắp hết hàng</label>
        </div>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-outline-primary w-100">Lọc</button>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table">
        <thead>
          <tr><th>Mã SP</th><th>Tên sản phẩm</th><th>Danh mục</th><th>Giá nhập</th><th>Giá bán</th><th>Tồn kho</th><th>Thao tác</th></tr>
        </thead>
        <tbody>
          <% if (products && products.length > 0) { %>
            <% products.forEach(p => { %>
            <tr>
              <td><span class="badge bg-light text-dark"><%= p.code %></span></td>
              <td><strong><%= p.name %></strong></td>
              <td><%= p.category %></td>
              <td><%= p.cost.toLocaleString('vi-VN') %>đ</td>
              <td><%= p.price.toLocaleString('vi-VN') %>đ</td>
              <td>
                <% if (p.isLowStock) { %>
                <span class="badge bg-danger"><%= p.quantity %></span>
                <% } else { %>
                <span class="badge bg-success"><%= p.quantity %></span>
                <% } %>
              </td>
              <td>
                <a href="/products/edit/<%= p._id %>" class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></a>
                <form method="POST" action="/products/delete/<%= p._id %>" class="d-inline" onsubmit="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="7" class="text-center text-muted py-5">Không tìm thấy sản phẩm nào</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
