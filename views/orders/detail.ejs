<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card">
      <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center py-3">
        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Chi tiết đơn hàng <%= order.orderCode %></h5>
        <span class="badge bg-<%= order.status === 'completed' ? 'success' : order.status === 'cancelled' ? 'danger' : order.status === 'processing' ? 'info' : 'warning' %> fs-6">
          <%= order.status === 'pending' ? 'Chờ xử lý' : order.status === 'processing' ? 'Đang xử lý' : order.status === 'completed' ? 'Hoàn thành' : 'Đã hủy' %>
        </span>
      </div>
      <div class="card-body">
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <div class="text-muted small">Khách hàng</div>
            <div class="fw-medium"><%= order.customerName %></div>
          </div>
          <div class="col-md-6">
            <div class="text-muted small">Số điện thoại</div>
            <div class="fw-medium"><%= order.customerPhone || '-' %></div>
          </div>
          <div class="col-md-6">
            <div class="text-muted small">Địa chỉ</div>
            <div class="fw-medium"><%= order.customerAddress || '-' %></div>
          </div>
          <div class="col-md-6">
            <div class="text-muted small">Phương thức thanh toán</div>
            <div class="fw-medium"><%= order.paymentMethod === 'cash' ? 'Tiền mặt' : 'Chuyển khoản' %></div>
          </div>
          <div class="col-md-6">
            <div class="text-muted small">Ngày tạo</div>
            <div class="fw-medium"><%= order.createdAt.toLocaleString('vi-VN') %></div>
          </div>
          <% if (order.notes) { %>
          <div class="col-12">
            <div class="text-muted small">Ghi chú</div>
            <div class="fw-medium"><%= order.notes %></div>
          </div>
          <% } %>
        </div>

        <h6 class="fw-medium mb-3">Sản phẩm</h6>
        <div class="table-responsive">
          <table class="table">
            <thead><tr><th>Sản phẩm</th><th>Đơn giá</th><th>Số lượng</th><th>Thành tiền</th></tr></thead>
            <tbody>
              <% order.items.forEach(item => { %>
              <tr>
                <td><%= item.product ? item.product.name : 'Sản phẩm đã xóa' %></td>
                <td><%= item.unitPrice.toLocaleString('vi-VN') %>đ</td>
                <td><%= item.quantity %></td>
                <td class="fw-medium"><%= item.totalPrice.toLocaleString('vi-VN') %>đ</td>
              </tr>
              <% }) %>
            </tbody>
            <tfoot class="table-group-divider">
              <tr><td colspan="3" class="text-end fw-medium">Tổng tiền:</td><td class="fw-bold text-danger"><%= order.totalAmount.toLocaleString('vi-VN') %>đ</td></tr>
              <tr><td colspan="3" class="text-end fw-medium">Lợi nhuận:</td><td class="fw-bold text-success"><%= order.profit.toLocaleString('vi-VN') %>đ</td></tr>
            </tfoot>
          </table>
        </div>

        <div class="d-flex gap-2 mt-3">
          <form method="POST" action="/orders/status/<%= order._id %>" class="d-flex gap-2">
            <% if (order.status !== 'completed') { %>
            <button type="submit" name="status" value="completed" class="btn btn-success"><i class="bi bi-check-lg me-1"></i>Hoàn thành</button>
            <% } %>
            <% if (order.status !== 'cancelled') { %>
            <button type="submit" name="status" value="cancelled" class="btn btn-danger"><i class="bi bi-x-lg me-1"></i>Hủy đơn</button>
            <% } %>
          </form>
          <a href="/orders" class="btn btn-outline-secondary">Quay lại</a>
        </div>
      </div>
    </div>
  </div>
</div>
